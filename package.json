{
  "name": "intelligent-bistro",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node ./scripts/run-expo.js start",
    "tunnel:start": "node ./scripts/start-with-ngrok.js",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "node ./scripts/run-expo.js start --android",
    "ios": "node ./scripts/run-expo.js start --ios",
    "web": "node ./scripts/run-expo.js start --web",
    "lint": "node ./scripts/run-expo.js lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:snapshots": "vitest run tests/snapshots",
    "test:perf": "vitest run tests/performance",
    "test:update-snapshots": "vitest run --update-snapshots tests/snapshots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "fuse.js": "^6.6.2",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "~19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "msw": "^2.14.6",
    "ngrok": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^2.1.9"
  },
  "private": true
}
